---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BitRotBanner from '../../components/BitRotBanner.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const readmes = await getCollection('readmes');
  const tools = readmes.filter(r => r.data.type === 'tool');
  return tools.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} | Tools`} description={project.data.description || ''} schemaType="SoftwareApplication">
  {project.data.status === 'deprecated' && (
    <BitRotBanner message="Deprecated: Requires Update. This tool is no longer actively maintained." />
  )}
  
  <article class="tool-content">
    <header>
      <h1>{project.data.title}</h1>
      {project.data.description && <p class="description">{project.data.description}</p>}
      <div class="meta">
        <span class={`status badge-${project.data.status}`}>{project.data.status}</span>
      </div>
    </header>
    
    <div class="content-body markdown-body">
      {project.body && project.body.trim() ? <Content /> : <p>No documentation provided.</p>}
    </div>
  </article>
</BaseLayout>

<style>
  .tool-content {
    max-width: var(--layout-content-max);
    margin: 0 auto;
  }
  
  header {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--border-color);
  }
  
  h1 {
    font-size: var(--font-size-2xl);
    margin-bottom: var(--space-sm);
    color: var(--text-primary);
  }
  
  .description {
    font-size: var(--font-size-lg);
    color: var(--text-muted);
    margin-bottom: var(--space-md);
  }
  
  .meta {
    display: flex;
    gap: var(--space-md);
  }
  
  .status {
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--border-radius-sm);
    font-size: var(--font-size-sm);
    font-weight: 500;
    text-transform: uppercase;
    background-color: var(--surface-card);
    border: 1px solid var(--border-color);
  }
  
  .badge-active {
    color: var(--accent-primary);
  }
  
  .badge-deprecated {
    color: var(--text-muted);
    text-decoration: line-through;
  }
  
  .badge-archived {
    color: var(--text-muted);
  }
</style>
