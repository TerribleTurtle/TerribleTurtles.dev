---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404: Not Found | TerribleTurtles.dev" description="Page not found.">
  <div class="error-container">
    <h1>404</h1>
    <p class="message">The requested path does not exist.</p>
    
    <div class="actions">
      <a href="/" class="btn">Return Home</a>
    </div>
  </div>
</BaseLayout>

<style>
  .error-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 50vh;
    text-align: center;
  }
  
  h1 {
    font-size: 6rem;
    font-family: var(--font-mono);
    color: var(--text-primary);
    margin-bottom: 1rem;
    line-height: 1;
  }
  
  .message {
    font-size: 1.5rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }
  
  .btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background-color: var(--text-primary);
    color: var(--bg-base);
    text-decoration: none;
    border-radius: 0.25rem;
    font-weight: 600;
    transition: opacity 0.2s;
  }
  
  .btn:hover {
    opacity: 0.9;
  }
</style>
