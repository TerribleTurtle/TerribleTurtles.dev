---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'TerribleTurtles.dev', description = 'A highly performant portfolio and tool-hosting platform.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <header>
      <div class="container">
        <nav aria-label="Primary">
          <!-- Header Menu: Home, Tools, Sites from SDD -->
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/tools">Tools</a></li>
            <li><a href="/sites">Sites</a></li>
          </ul>
        </nav>
      </div>
    </header>
    
    <main id="main" class="container">
      <slot />
    </main>

    <footer>
      <div class="container">
        <nav aria-label="Footer">
          <!-- Footer Menu: About, Privacy, Security, Changelog / RSS from SDD -->
          <ul>
            <li><a href="/about">About</a></li>
            <li><a href="/privacy">Privacy</a></li>
            <li><a href="/security">Security</a></li>
          </ul>
        </nav>
      </div>
    </footer>
  </body>
</html>

<style>
  main {
    flex: 1;
    width: 100%;
    padding-top: var(--space-xl);
  }

  header nav ul, footer nav ul {
    display: flex;
    gap: var(--space-md);
    list-style: none;
    padding: var(--space-md) 0;
    margin: 0;
  }
  
  header {
    border-bottom: 1px solid var(--border-color);
    width: 100%;
  }
  
  footer {
    border-top: 1px solid var(--border-color);
    margin-top: auto;
    width: 100%;
  }
  
  .skip-link {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }
  
  .skip-link:focus-visible {
    position: absolute;
    top: var(--space-md);
    left: var(--space-md);
    width: auto;
    height: auto;
    margin: 0;
    overflow: visible;
    clip-path: none;
    white-space: normal;
    background: var(--accent-primary);
    color: var(--bg-base);
    padding: var(--space-sm) var(--space-md);
    z-index: 100;
    border-radius: var(--border-radius);
  }
</style>
