---
import { getCollection } from 'astro:content';

const readmes = await getCollection('readmes');
const activeProjects = readmes.filter(r => r.data.status === 'active');

const projects = activeProjects.map(p => ({
  id: p.id,
  title: p.data.title,
  type: p.data.type,
  url: `/${p.data.type}s/${p.id}`
}));
---

<dialog id="command-palette" aria-label="Command Palette">
  <div class="palette-container">
    <div class="search-header">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input type="text" id="palette-search" placeholder="Search projects..." />
      <button id="palette-close" aria-label="Close Command Palette">
        <kbd>ESC</kbd>
      </button>
    </div>
    <ul id="palette-results">
      {projects.map(project => (
        <li class="result-item" data-title={project.title.toLowerCase()} data-url={project.url}>
          <a href={project.url} tabindex="-1">
            <span class="result-title">{project.title}</span>
            <span class="result-type">{project.type}</span>
          </a>
        </li>
      ))}
    </ul>
    <div id="palette-empty" class="hidden">
      No projects found.
    </div>
  </div>
</dialog>

<script src="/scripts/command-palette.js" is:inline></script>

<style>
  dialog::backdrop {
    background: color-mix(in srgb, var(--bg-base) 80%, transparent);
    backdrop-filter: blur(4px);
  }

  dialog {
    padding: 0;
    margin: var(--space-2xl) auto auto;
    width: 90%;
    max-width: var(--layout-content-max);
    background-color: var(--surface-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius);
    color: var(--text-primary);
    /* stylelint-disable-next-line color-function-alias-notation, color-function-notation, function-disallowed-list, alpha-value-notation */
    box-shadow: 0 10px 25px -5px rgb(0 0 0 / 50%);
  }

  .palette-container {
    display: flex;
    flex-direction: column;
    max-height: 80vh;
  }

  .search-header {
    display: flex;
    align-items: center;
    padding: var(--space-md);
    border-bottom: 1px solid var(--border-color);
    gap: var(--space-sm);
  }

  .search-header svg {
    color: var(--text-muted);
  }

  #palette-search {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--text-primary);
    font-size: var(--font-size-base);
    font-family: var(--font-sans);
    outline: none;
  }
  
  #palette-search::placeholder {
    color: var(--text-muted);
  }

  #palette-close {
    background: transparent;
    border: none;
    cursor: pointer;
    padding: var(--space-sm);
    display: flex;
    align-items: center;
  }

  kbd {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    padding: var(--space-xs) var(--space-sm);
    background-color: var(--bg-base);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-sm);
    color: var(--text-muted);
  }

  #palette-results {
    list-style: none;
    margin: 0;
    padding: var(--space-sm);
    overflow-y: auto;
  }

  .result-item {
    border-radius: var(--border-radius-sm);
  }

  .result-item a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    text-decoration: none;
    color: var(--text-primary);
    border-radius: var(--border-radius-sm);
    outline: none;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .result-item.selected a,
  .result-item:hover a {
    /* stylelint-disable-next-line declaration-property-value-allowed-list */
    background-color: color-mix(in srgb, var(--accent-primary) 15%, transparent);
  }
  
  .result-title {
    font-weight: 500;
  }
  
  .result-type {
    font-size: var(--font-size-sm);
    color: var(--text-muted);
    font-family: var(--font-mono);
    text-transform: capitalize;
  }

  .hidden {
    display: none;
  }

  #palette-empty {
    padding: var(--space-xl);
    text-align: center;
    color: var(--text-muted);
  }
</style>
