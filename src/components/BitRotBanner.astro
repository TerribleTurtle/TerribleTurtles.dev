---
export interface Props {
  message: string;
}
const { message } = Astro.props;
---

<div class="bit-rot-banner" role="alert">
  <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/>
    <line x1="12" y1="9" x2="12" y2="13"/>
    <line x1="12" y1="17" x2="12.01" y2="17"/>
  </svg>
  <span>{message}</span>
</div>

<style>
  .bit-rot-banner {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    background-color: var(--surface-card);
    color: var(--text-primary);
    border: 1px solid var(--accent-primary);
    padding: var(--space-md);
    border-radius: var(--border-radius);
    margin-bottom: var(--space-xl);
    font-weight: 500;
  }
  
  .bit-rot-banner svg {
    flex-shrink: 0;
    color: var(--accent-primary);
  }
</style>
