---
interface Props {
  title: string;
  description: string;
  link: string;
  tags?: string[];
  headingLevel?: "h2" | "h3";
}

const { title, description, link, tags = [], headingLevel = "h3" } = Astro.props;
const descId = `desc-${title.toLowerCase().replace(/\W+/g, '-')}-${link.replace(/\W+/g, '')}`;
const TitleTag = headingLevel;
---

<article class="project-card">
  <header>
    <TitleTag><a href={link} class="card-link" aria-describedby={descId}>{title}</a></TitleTag>
  </header>
  <div class="content">
    <p id={descId}>{description}</p>
  </div>
  {tags.length > 0 && (
    <footer>
      <ul class="tags" aria-label="Project tags">
        {tags.map((tag) => (
          <li>{tag}</li>
        ))}
      </ul>
    </footer>
  )}
</article>

<style>
  .project-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    background-color: var(--surface-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius);
    padding: var(--space-lg);
    color: var(--text-primary);
    transition: transform 0.2s ease, border-color 0.2s ease;
    height: 100%;
  }

  .project-card::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: calc(var(--border-radius) + 1px);
    background: linear-gradient(145deg, color-mix(in srgb, var(--accent-primary) 40%, transparent), transparent 60%);
    z-index: -1;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .project-card:hover,
  .project-card:focus-within {
    transform: translateY(var(--offset-interaction));
    /* stylelint-disable-next-line declaration-property-value-allowed-list */
    border-color: color-mix(in srgb, var(--accent-primary) 50%, transparent);
    /* stylelint-disable-next-line color-function-alias-notation, color-function-notation, function-disallowed-list, alpha-value-notation */
    box-shadow: 0 10px 20px -10px rgb(0 0 0 / 50%);
  }

  .project-card:hover::before,
  .project-card:focus-within::before {
    opacity: 1;
  }

  .card-link {
    color: var(--text-primary);
    text-decoration: none;
  }
  
  .card-link::after {
    content: "";
    position: absolute;
    inset: 0;
  }
  
  .card-link:focus-visible {
    outline: none;
  }

  header h2,
  header h3 {
    margin: 0;
    font-size: var(--font-size-lg);
    color: var(--text-primary);
  }

  .content {
    flex: 1;
  }

  .content p {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--font-size-base);
    line-height: 1.5;
  }

  footer {
    margin-top: auto;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tags li {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    padding: var(--space-xs) var(--space-sm);
    background-color: var(--bg-base);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-sm);
    color: var(--text-tag);
  }
</style>
