---
interface Props {
  title: string;
  description: string;
  link: string;
  tags?: string[];
}

const { title, description, link, tags = [] } = Astro.props;
const descId = `desc-${title.toLowerCase().replace(/\\W+/g, '-')}`;
---

<article class="project-card">
  <header>
    <h3><a href={link} class="card-link" aria-describedby={descId}>{title}</a></h3>
  </header>
  <div class="content">
    <p id={descId}>{description}</p>
  </div>
  {tags.length > 0 && (
    <footer>
      <ul class="tags" aria-label="Project tags">
        {tags.map((tag) => (
          <li>{tag}</li>
        ))}
      </ul>
    </footer>
  )}
</article>

<style>
  .project-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    background-color: var(--surface-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius);
    padding: var(--space-lg);
    color: var(--text-primary);
    transition: transform 0.2s ease, border-color 0.2s ease;
    height: 100%;
  }

  .project-card:hover,
  .project-card:focus-within {
    transform: translateY(-2px);
    border-color: var(--accent-primary);
  }

  .card-link {
    color: var(--text-primary);
    text-decoration: none;
  }
  
  .card-link::after {
    content: "";
    position: absolute;
    inset: 0;
  }
  
  .card-link:focus-visible {
    outline: none;
  }

  header h3 {
    margin: 0;
    font-size: 1.25rem;
    color: var(--text-primary);
  }

  .content {
    flex: 1;
  }

  .content p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  footer {
    margin-top: auto;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tags li {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: var(--space-xs) var(--space-sm);
    background-color: var(--bg-base);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-sm);
    color: var(--text-tag);
  }
</style>
