{
  "name": "popular-point",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"**/*.{css,astro}\"",
    "typecheck": "astro check",
    "build": "npm run typecheck && npm run lint:js && npm run lint:css && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "deploy": "npm run build",
    "test": "vitest run",
    "audit": "start-server-and-test preview http://localhost:4321 'node scripts/audit.mjs'",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "astro": "^7.0.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/cli": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.19",
    "postcss-html": "^1.8.1",
    "start-server-and-test": "^3.0.11",
    "stylelint": "^17.14.0",
    "stylelint-config-astro": "^2.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  },
  "lint-staged": {
    "*.{js,ts,mjs}": "eslint",
    "*.{css,astro}": "stylelint"
  }
}
